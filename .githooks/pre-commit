#!/usr/bin/env bash
#
# pre-commit — fast subset only (gofmt + go vet + lint if installed).
# Tests run on push (pre-push) and in CI; keep commits snappy.
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

unformatted="$(gofmt -l . | grep -v '^vendor/' || true)"
if [ -n "$unformatted" ]; then
	echo "gofmt found unformatted files:" >&2
	echo "$unformatted" >&2
	echo "hint: run 'gofmt -w .'" >&2
	exit 1
fi

go vet ./...

if command -v golangci-lint >/dev/null 2>&1; then
	golangci-lint run
fi

echo "pre-commit OK"
